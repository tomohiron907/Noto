{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window (desktop only)",
  "platforms": [
    "macOS",
    "windows",
    "linux"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:allow-open",
    "store:allow-get",
    "store:allow-set",
    "store:allow-load",
    "store:allow-save",
    "deep-link:default"
  ]
}